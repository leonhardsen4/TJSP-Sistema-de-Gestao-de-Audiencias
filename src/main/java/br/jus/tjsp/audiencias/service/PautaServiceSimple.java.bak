package br.jus.tjsp.audiencias.service;

import com.itextpdf.kernel.pdf.PdfDocument;
import com.itextpdf.kernel.pdf.PdfWriter;
import com.itextpdf.layout.Document;
import com.itextpdf.layout.element.Paragraph;
import org.springframework.stereotype.Service;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.io.ByteArrayOutputStream;
import java.time.LocalDate;

@Service
public class PautaServiceSimple {

    private static final Logger logger = LoggerFactory.getLogger(PautaServiceSimple.class);

    public byte[] gerarPDFSimples(LocalDate data) throws Exception {
        logger.info("Iniciando geração de PDF simples para a data: {}", data);
        
        try {
            ByteArrayOutputStream baos = new ByteArrayOutputStream();
            PdfWriter writer = new PdfWriter(baos);
            PdfDocument pdfDoc = new PdfDocument(writer);
            Document document = new Document(pdfDoc);

            logger.info("Documento PDF criado com sucesso");

            // Adicionar apenas um parágrafo simples
            document.add(new Paragraph("Teste de PDF - Data: " + data.toString()));
            document.add(new Paragraph("Este é um teste simples de geração de PDF."));

            logger.info("Conteúdo adicionado ao PDF");
            
            document.close();
            byte[] pdfBytes = baos.toByteArray();
            logger.info("PDF simples gerado com sucesso. Tamanho: {} bytes", pdfBytes.length);
            return pdfBytes;
            
        } catch (Exception e) {
            logger.error("Erro durante a geração do PDF simples para a data {}: {}", data, e.getMessage(), e);
            throw e;
        }
    }
}